{
  "name": "code-cache-mcp",
  "version": "0.1.0",
  "description": "MCP server providing a persistent, tree-sitter-backed code knowledge cache for AI agents.",
  "type": "module",
  "workspaces": [
    "packages/sdk",
    "packages/server"
  ],
  "scripts": {
    "start": "npx tsx packages/server/src/index.ts",
    "report": "npx tsx packages/server/src/report.ts",
    "test": "npx tsx --test 'packages/sdk/src/**/*.test.ts'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@tursodatabase/database": "^0.6.0",
    "@xenova/transformers": "^2.17.2",
    "glob": "^11.0.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-python": "^0.23.4",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.24.7",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "bun-types": "latest",
    "typescript": "^5.0.0"
  },
  "license": "MIT"
}
